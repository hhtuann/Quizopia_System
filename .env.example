# ============================================================
# Quizopia environment variables (TEMPLATE ONLY).
#
# Copy this file to ".env" in the repository root and replace the
# placeholder values with real secrets generated locally. NEVER
# commit a real ".env" file. These values are read by docker-compose
# and passed to the backend service.
# ============================================================

# HS256 JWT signing key: Base64 encoding of AT LEAST 32 random bytes.
# Generate with:
#   openssl rand -base64 48
QUIZOPIA_JWT_SECRET_BASE64=__replace_with_base64_of_at_least_32_random_bytes__

# AES-256-GCM data-encryption key: Base64 encoding of EXACTLY 32 random bytes.
# Generate with:
#   openssl rand -base64 32
QUIZOPIA_DATA_ENCRYPTION_KEY_BASE64=__replace_with_base64_of_exactly_32_random_bytes__

# Invite code required to create a TEACHER account via public registration.
QUIZOPIA_TEACHER_INVITE_CODE=__replace_with_a_strong_invite_code__

# Comma-separated list of allowed CORS origins.
QUIZOPIA_ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" in production to mark refresh cookies as Secure.
QUIZOPIA_COOKIE_SECURE=false

# Seed demo accounts (one per role: sysadmin, academic admin, teacher, 4 students)
# plus a demo classroom on the backend's first startup. Set to "true" to try the
# app quickly; leave "false" for production. Demo password: Demo@12345.
QUIZOPIA_DEMO_DATA_ENABLED=false
